      - Container10:
          Control: GroupContainer@1.5.0
          Variant: ManualLayout
          Properties:
            Fill: =RGBA(255, 255, 255, 1)
            Height: =38
            Width: =352
            X: =1000
            Y: =58
          Children:
            - ButtonCanvas5:
                Control: Button@0.0.45
                Properties:
                  Appearance: ='ButtonCanvas.Appearance'.Secondary
                  BorderColor: =RGBA(0, 0, 0, 1)
                  BorderStyle: =BorderStyle.Solid
                  Font: =Font.Verdana
                  FontSize: =11
                  Height: =25
                  Icon: ="Edit"
                  OnSelect: =Set(varEditMode, true);
                  Text: ="편집"
                  Visible: =!varEditMode
                  Width: =70
                  X: =278
                  Y: =7
            - Send_btn:
                Control: Button@0.0.45
                Properties:
                  Appearance: ='ButtonCanvas.Appearance'.Secondary
                  BorderColor: =RGBA(0, 0, 0, 1)
                  BorderStyle: =BorderStyle.Solid
                  BorderThickness: =0.5
                  Font: =Font.Verdana
                  FontSize: =11
                  Height: =25
                  Icon: ="Send"
                  IconStyle: ='ButtonCanvas.IconStyle'.Filled
                  OnSelect: "=// 0) 이번 저장 시도에서 저장 성공 여부 초기화\r\nSet(varSaveSuccess, false);\r\n\r\n// 1) Daily_Gallery에서 사용자 입력(작업시간/내용)을 colDailyTasks에 반영\r\nForAll(\r\n    Daily_Gallery.AllItems,\r\n    Patch(\r\n        colDailyTasks,\r\n        ThisRecord,\r\n        {\r\n            작업시간: Value(txtWorkHour.Value),\r\n            작업내용: txtWorkContent.Value,\r\n\r\n            // ✅ 작업_분류도 저장 시점에만 반영\r\n            작업_분류: If(\r\n                ddWorkTag.Selected.Tag = \"— 미선택 —\",\r\n                Blank(),\r\n                ddWorkTag.Selected.Tag\r\n            )\r\n        }\r\n    )\r\n);\r\n\r\n// 2) colDailyTasks ➜ Daily_DB  (반복 제한 + 안내 + 단일/기간 분기)\r\nWith(\r\n    {\r\n        _isRepeat: tglRepeat.Checked,\r\n        _start:    dpRepeatStart.SelectedDate,\r\n        _end:      dpRepeatEnd.SelectedDate,\r\n        _days:     DateDiff(dpRepeatStart.SelectedDate, dpRepeatEnd.SelectedDate) + 1\r\n    },\r\n    \r\n    // 2-1) 반복 모드 + 15일 초과면 → 에러 알림 후 종료 (저장 안 함)\r\n    If(\r\n        _isRepeat && _days > 15,\r\n        Notify(\r\n            \"기간 반복 입력은 최대 15일까지 가능합니다. 현재 선택: \" & Text(_days) & \"일\",\r\n            NotificationType.Error\r\n        ),\r\n        \r\n        // 2-2) 15일 이내라면 → (반복/단일 모드에 따라 처리)\r\n        If(\r\n            _isRepeat,\r\n            \r\n            /* ===================================================================\r\n               \U0001F7E3 기간 반복 입력 모드 (tglRepeat = On, 15일 이하)\r\n               =================================================================== */\r\n\r\n            // 저장 전 안내 메시지\r\n            Notify(\r\n                Text(_start, \"yyyy년 m월 d일\") & \" ~ \" &\r\n                Text(_end, \"yyyy년 m월 d일\") &\r\n                \" (\" & Text(_days) & \"일) 동안 동일한 업무가 등록됩니다.\",\r\n                NotificationType.Information\r\n            );\r\n\r\n            // 2-2-1) 대상 날짜 컬렉션 생성\r\n            ClearCollect(\r\n                colTargetDates,\r\n                AddColumns(\r\n                    Sequence(_days),\r\n                    TargetDate,\r\n                    DateAdd(_start, Value - 1, TimeUnit.Days)\r\n                )\r\n            );\r\n            \r\n            // 2-2-2) 각 날짜 × 각 업무(colDailyTasks)를 Daily_DB에 Insert (항상 추가, 기존 데이터 보존)\r\n            ForAll(\r\n                colTargetDates As dt,\r\n                ForAll(\r\n                    colDailyTasks As d,\r\n                    With(\r\n                        {\r\n                            newRec: Patch(\r\n                                Daily_DB,\r\n                                Defaults(Daily_DB),\r\n                                {\r\n                                    작성자:          name_label.Text,\r\n                                    프로젝트명:      d.c프로젝트명,\r\n                                    업무_계정:       d.c업무_계정,\r\n                                    업무_시작일자:   d.c업무_시작일자,\r\n                                    업무_종료일자:   d.c업무_종료일자,\r\n                                    업무제목:        d.c업무제목,\r\n                                    상세_업무내용:   d.c상세_업무내용,\r\n                                    상태:            d.c상태,\r\n                                    작업내용:        d.작업내용,\r\n                                    작업시간:        d.작업시간,\r\n                                    작성일자:        dt.TargetDate,     // ★ 날짜만 TargetDate로\r\n                                    팀: LookUp(UserInfo_DB, 이름_한글 = name_label.Text).팀,\r\n                                    작업_분류: d.작업_분류\r\n                                }\r\n                            )\r\n                        },\r\n                        // 새 ID를 colDailyTasks에 반영 (다음 저장 시 중복 Insert 방지용, 원래 로직 유지)\r\n                        Patch(\r\n                            colDailyTasks,\r\n                            d,\r\n                            { ID: newRec.ID }\r\n                        )\r\n                    )\r\n                )\r\n            );\r\n\r\n            // 반복 모드에서 실제로 저장 완료 → 성공 플래그 세팅\r\n            Set(varSaveSuccess, true),\r\n\r\n/* ===================================================================\r\n   \U0001F535 단일 날짜 모드 (tglRepeat = Off) - 수정/신규 분기 저장\r\n   =================================================================== */\r\n\r\nForAll(\r\n    colDailyTasks As d,\r\n\r\n    If(\r\n        // ✅ [수정] 기존 Daily_DB 레코드: ID가 있으면 Update\r\n        !IsBlank(d.ID),\r\n\r\n        Patch(\r\n            Daily_DB,\r\n            LookUp(Daily_DB, ID = d.ID),\r\n            {\r\n                작업내용:  d.작업내용,\r\n                작업시간:  d.작업시간,\r\n                작업_분류:  d.작업_분류\r\n            }\r\n        ),\r\n\r\n        // ✅ [신규] 새로 추가한 줄: ID가 Blank면 Insert\r\n        With(\r\n            {\r\n                newRec: Patch(\r\n                    Daily_DB,\r\n                    Defaults(Daily_DB),\r\n                    {\r\n                        작성자:          name_label.Text,\r\n                        프로젝트명:      d.c프로젝트명,\r\n                        업무_계정:       d.c업무_계정,\r\n                        업무_시작일자:   DateTimeValue(d.c업무_시작일자),\r\n                        업무_종료일자:   DateTimeValue(d.c업무_종료일자),\r\n                        업무제목:        d.c업무제목,\r\n                        상세_업무내용:   d.c상세_업무내용,\r\n                        상태:            d.c상태,\r\n                        작업내용:        d.작업내용,\r\n                        작업시간:        d.작업시간,\r\n                        작성일자:        varSelectedDate,\r\n                        팀: LookUp(UserInfo_DB, 이름_한글 = name_label.Text).팀,\r\n                        작업_분류:       d.작업_분류\r\n                    }\r\n                )\r\n            },\r\n            Patch(\r\n                colDailyTasks,\r\n                d,\r\n                { ID: newRec.ID, HasDaily: true }\r\n            )\r\n        )\r\n    )\r\n);\r\n\r\n\r\n\r\n            // 단일 모드에서도 Patch까지 끝나면 성공 플래그 세팅\r\n            Set(varSaveSuccess, true)\r\n        )\r\n    )\r\n);\r\n\r\n// 3) 토스트 & 편집모드 종료 (저장 성공일 때만 실행)\r\nIf(\r\n    varSaveSuccess,\r\n    Set(varToastMessage2, \"저장이 완료되었습니다 \");\r\n    Set(varShowToast2, true);\r\n    Set(varEditMode, false);\r\n    toastTimer2.Start\r\n);\r\n\r\n//다중 입력 토글 리셋\r\nReset(tglRepeat)"
                  Text: |+
                    =If(
                        tglRepeat.Checked,
                        "저장(" &
                            Text(
                                DateDiff(
                                    dpRepeatStart.SelectedDate,
                                    dpRepeatEnd.SelectedDate
                                ) + 1
                            ) & "일)",
                        "저장"
                    )
                  Visible: |+
                    =varEditMode
                  Width: |-
                    =If(
                        tglRepeat.Checked,
                        108
                        ,    // 반복 모드일 때 넓게
                        70     // 기본 모드일 때 좁게
                    )
                  X: |-
                    =If(
                        tglRepeat.Checked,
                        165    ,    // 반복 모드일 때 넓게
                        200     // 기본 모드일 때 좁게
                    )
                  Y: =7
            - Dates_label:
                Control: FluentV8/Label@1.8.6
                Properties:
                  Alignment: =Align.Left
                  Font: =Font.Verdana
                  FontSize: =9.5
                  FontWeight: =FontWeight.Normal
                  Height: =29
                  Text: |+
                    =Text(
                        varSelectedDate,
                        "yyyy년 m월 d일"
                    )
                  VerticalAlignment: =VerticalAlign.Middle
                  Width: =150
                  X: =15
                  Y: =5
            - Cancle_btn:
