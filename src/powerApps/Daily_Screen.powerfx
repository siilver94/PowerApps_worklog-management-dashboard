                  Value: |+
                    =""
                  Width: =180
                  X: =10
                  Y: =33
            - Rectangle3_2:
                Control: Rectangle@2.3.0
                Properties:
                  BorderColor: =RGBA(243, 242, 241, 1)
                  BorderStyle: =BorderStyle.None
                  BorderThickness: =1
                  DisabledFill: =RGBA(200, 198, 196, 1)
                  Fill: =RGBA(0, 0, 0, 0.49)
                  FocusedBorderColor: =RGBA(98, 100, 167, 1)
                  Height: =0.4
                  HoverFill: =RGBA(98, 100, 167, 1)
                  PressedFill: =RGBA(98, 100, 167, 1)
                  Width: =179
                  X: =10
                  Y: =58
            - chkCompleted:
                Control: CheckBox@0.0.30
                Properties:
                  Checked: =varShowCompleted
                  Font: =Font.Verdana
                  FontSize: =10
                  FontWeight: =FontWeight.Semibold
                  Height: =22
                  Label: ="완료"
                  OnCheck: =	Collect(colSelStatus, {Value:"완료"})
                  OnUncheck: =RemoveIf(colSelStatus, Value="완료")
                  Width: =80
                  X: =164
                  Y: =6
            - chkPlanned:
                Control: CheckBox@0.0.30
                Properties:
                  Checked: =varShowPlanned
                  Font: =Font.Verdana
                  FontSize: =10
                  FontWeight: =FontWeight.Semibold
                  Height: =22
                  Label: ="시작전"
                  OnCheck: =Collect(colSelStatus, {Value:"시작전"})
                  OnUncheck: =RemoveIf(colSelStatus, Value="시작전")
                  Width: =80
                  Y: =6
            - chkInProgress:
                Control: CheckBox@0.0.30
                Properties:
                  Checked: =	"진행중" in colSelStatus.Value
                  Font: =Font.Verdana
                  FontSize: =10
                  FontWeight: =FontWeight.Semibold
                  Height: =22
                  Label: ="진행중"
                  OnCheck: =Collect(colSelStatus, {Value:"진행중"})
                  OnUncheck: =RemoveIf(colSelStatus, Value="진행중")
                  Width: =80
                  X: =82
                  Y: =6
      - con_ShowDelPopup:
          Control: GroupContainer@1.5.0
          Variant: ManualLayout
          Properties:
            Fill: =RGBA(255, 255, 255, 1)
            Height: =135
            Visible: =ShowDelPopup
            Width: =336
            X: =515
            Y: =309
          Children:
            - del_title:
                Control: Text@0.0.51
                Properties:
                  Align: ='TextCanvas.Align'.Center
                  Font: =Font.Verdana
                  Size: =15
                  Text: ="일일 업무일지를 삭제하시겠습니까?"
                  VerticalAlign: =VerticalAlign.Middle
                  Width: =336
                  Y: =21
            - btn_Delete_yes:
                Control: Button@0.0.45
                Properties:
                  Appearance: ='ButtonCanvas.Appearance'.Secondary
                  Font: =Font.Verdana
                  FontSize: =12
                  OnSelect: |-
                    =If(
                        !IsBlank(gblDelRecord),
                        // 1) 화면 컬렉션에서 제거
                        Remove(colDailyTasks, gblDelRecord);

                        // 2) 원본 데이터에서도 제거 (ID 필드 이름 맞춰 수정)
                        If(
                            !IsBlank(gblDelRecord.ID),
                            RemoveIf(Daily_DB, ID = gblDelRecord.ID)
                        )
                    );

                    // 3) 팝업 닫기 & 변수 초기화
                    Set(ShowDelPopup,false);
                    Set(gblDelRecord, Blank());

                    Set(varToastMessage2, "삭제가 완료되었습니다.");
                    Set(varShowToast2, true);
                    toastTimer2.Start
                  Text: ="예"
                  Width: =88
                  X: =61
                  Y: =83
            - btn_Delete_no:
                Control: Button@0.0.45
                Properties:
                  Appearance: ='ButtonCanvas.Appearance'.Secondary
                  Font: =Font.Verdana
                  FontSize: =12
                  OnSelect: |-
                    =Set(ShowDelPopup,false);
                    Set(gblDelRecord, Blank());
                  Text: ="아니오"
                  Width: =88
                  X: =187
                  Y: =83
