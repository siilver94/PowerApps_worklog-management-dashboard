                        varEditMode, 
                        RGBA(174, 208, 221, 0.1),  // 편집 가능(흰색)
                        RGBA(245, 245, 245, 1)   // 편집 불가(연회색)
                    )
                  DelayOutput: |+
                    =false
                  Font: =Font.Verdana
                  FontSize: =9
                  Height: =25
                  Mode: ='TextBox.Mode'.SingleLine
                  OnChange: =
                  OnSelect: =
