                      Properties:
                        ColorBackground: |+
                          =If(
                              varEditMode, 
                              RGBA(174, 208, 221, 0.1),  // 편집 가능(흰색)
                              RGBA(245, 245, 245, 1)   // 편집 불가(연회색)
                          )
                        DelayOutput: |+
                          =false
                        DisplayMode: |+
                          =If(varEditMode , DisplayMode.Edit, DisplayMode.View)
                        Font: =Font.Verdana
