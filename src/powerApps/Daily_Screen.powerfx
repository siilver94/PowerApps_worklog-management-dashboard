                        OnChange: |-
                          =// 사용자가 직접 시간을 만지면 자동세팅 해제
                          UpdateContext({ locAutoHour: Blank() });
                        OnSelect: =Select(Parent)
                        Placeholder: |-
                          =If(
                              IsBlank(ThisItem.작업시간),
                              "",
                              Text(ThisItem.작업시간)
                          )
                        Value: |-
                          =If(
                              !IsBlank(locAutoHour),
                              locAutoHour,
                              ThisItem.작업시간
                          )
