                        Height: =20
                        Icon: ="Delete"
                        OnSelect: |+
                          =
                          Set(
                              gblDelRecord,      // ❶ 삭제 대상 저장 (Record 타입)
                              ThisItem
                          );
                          Set(ShowDelPopup,true);
                        Text: ="삭제"
                        Visible: |+
                          =varEditMode
                        Width: =65
                        X: =785
                        Y: =1
                  - btnFeedback:
                      Control: Button@0.0.45
                      Properties:
                        Appearance: ='ButtonCanvas.Appearance'.Secondary
                        BorderColor: =RGBA(0, 0, 0, 0.59)
                        BorderStyle: =BorderStyle.Solid
                        BorderThickness: =0.5
                        Font: =Font.Verdana
                        FontColor: =RGBA(15, 84, 140, 1)
                        FontSize: =11
                        Height: =20
                        OnSelect: |-
                          =ClearCollect(
                              colSelFB,
                              { 제목: ThisItem.업무제목, 내용: ThisItem.피드백 }
                          );
                          Set(varShowFB, true)
                        Text: ="피드백"
                        Visible: =!IsBlank(ThisItem.피드백)
                        Width: =70
                        X: =648
                        Y: =10
                  - ddWorkTag:
                      Control: DropDown@0.0.45
                      Properties:
                        Appearance: ='DropdownCanvas.Appearance'.FilledDarker
                        BorderColor: =RGBA(12, 59, 94, 1)
                        BorderStyle: =BorderStyle.Solid
                        DefaultSelectedItems: |-
                          =With(
                              { cur: Coalesce(ThisItem.작업_분류, "— 미선택 —") },
                              Filter(
                                  colWorkTagsMap,
                                  Account = ThisItem.c업무_계정 &&
                                  Tag = cur
                              )
                          )
                        DisplayMode: =If(varEditMode , DisplayMode.Edit, DisplayMode.View)
                        FontSize: =14
                        Items: |+
                          =SortByColumns(
                              Filter(
                                  colWorkTagsMap,
                                  Account = ThisItem.c업무_계정
                              ),
                              "Order",
                              SortOrder.Ascending
                          )
                        OnChange: |+
                          =// ✅ 연차(반차)일 때만 작업시간 자동 세팅
                          If(
                              ThisItem.c업무_계정 = "연차(반차)",
                              Switch(
                                  ddWorkTag.Selected.Tag,
                                  "연차",      Set(varAutoHour, 8),
                                  "오전반차",  Set(varAutoHour, 4),
                                  "오후반차",  Set(varAutoHour, 4),
                                  Set(varAutoHour, Blank())
                              )
                          );

                          // ✅ 자동값이 있으면 작업시간 입력칸에만 반영 (Reset 대신 SetFocus/Reset 없이 값만 바꾸는 방식은 어려워서, 최소 Reset 1회만)
                          // 여기서는 txtWorkHour에 "Default"를 쓰고 있다면 Reset이 필요할 수 있음.
                          // 단, Reset은 '연차/반차' 선택일 때만! (아래 If로 제한)
                          If(
                              ThisItem.c업무_계정 = "연차(반차)" &&
                              ddWorkTag.Selected.Tag in ["연차","오전반차","오후반차"],
                              UpdateContext({ locAutoHour: varAutoHour });
                              Reset(txtWorkHour)
                          );
                        Visible: |+
                          =varEditMode
                        Width: =130
                        X: =784
                        Y: =26
                      Children:
                        - Tag1:
                            Control: DropDownDataField@1.5.0
                            Variant: textualColumn
                            IsLocked: true
                            Properties:
                              FieldDisplayName: ="Tag"
                              FieldName: ="Tag"
                              FieldType: ="s"
                              Order: =1
                  - opWorkTag:
                      Control: Text@0.0.51
                      Properties:
                        Align: ='TextCanvas.Align'.Start
                        Font: =Font.Verdana
                        FontColor: =RGBA(17, 61, 15, 1)
                        Height: =18
                        Size: =10.5
                        Text: |+
                          ="[" &
                          Coalesce(
                              If(ddWorkTag.Selected.Tag = "— 미선택 —", Blank(), ddWorkTag.Selected.Tag),
                              ThisItem.작업_분류
                          ) &
                          "]"
                        VerticalAlign: =VerticalAlign.Middle
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =105
                        X: =598
                        Y: =42
      - Con_left:
          Control: GroupContainer@1.5.0
          Variant: ManualLayout
          Properties:
            Height: =347
            Width: =382
            X: =19
            Y: =408
          Children:
            - gal_Task_list:
                Control: Gallery@2.15.0
                Variant: BrowseLayout_Vertical_TwoTextOneImageVariant_pcfCore
                Properties:
                  BorderColor: =RGBA(243, 242, 241, 1)
                  FocusedBorderColor: =RGBA(98, 100, 167, 1)
                  FocusedBorderThickness: =2
                  Height: =347
                  Items: |+
                    =/* gal_Task_list.Items — 간단/안정 버전 */
                    With(
                        {
                            // ① 날짜+작성자(서버 위임)
                            src:
                                If(
                                    varFilterMode = "15Days",
                                    Filter(
                                        Task_DB,
                                        작성자 = name_label.Text,
                                        업무_시작일자 >= DateAdd(Today(), -7, TimeUnit.Days),
                                        업무_시작일자 <= DateAdd(Today(),  7, TimeUnit.Days)
                                    ),
                                    Filter(
                                        Task_DB,
                                        작성자 = name_label.Text,
                                        업무_시작일자 >= DateAdd(Today(), -365, TimeUnit.Days)
                                    )
                                ),

                            // ② 검색어(소문자+공백 제거)
                            key: With(
                                    { t: Trim(searchTxt.Value) },
                                    If(IsBlank(t), Blank(), Lower(Substitute(t, " ", "")))
                                 )
                        },

                        // ③ 상태 필터(위임 가능: 상수 비교 + OR)
                        //    → ④ 제목 '포함' 검색(로컬) 적용 → ⑤ 정렬
                        SortByColumns(
                            If(
                                IsBlank(key),
                                Filter(
                                    src,
                                    (chkPlanned.Checked    && 상태 = "시작전")  ||
                                    (chkInProgress.Checked && 상태 = "진행중") ||
                                    (chkCompleted.Checked  && 상태 = "완료")
                                ),
                                Filter(
                                    Filter(
                                        src,
                                        (chkPlanned.Checked    && 상태 = "시작전")  ||
                                        (chkInProgress.Checked && 상태 = "진행중") ||
                                        (chkCompleted.Checked  && 상태 = "완료")
                                    ),
                                    Find(
                                        key,
                                        Lower(Substitute(업무제목, " ", ""))
                                    ) > 0
                                )
                            ),
                            "OData__xc5c5__xbb34___xc2dc__xc791__xc",   // 내부 열 이름 맞춰주세요
                            SortOrder.Descending
                        )
                    )
                  TemplateSize: =73
                  Width: =382
                Children:
                  - Container2:
                      Control: GroupContainer@1.5.0
                      Variant: ManualLayout
                      Properties:
                        Fill: =RGBA(255, 255, 255, 1)
                        Height: =69
                        Width: =374
                  - Title1:
                      Control: FluentV8/Label@1.8.6
                      Properties:
                        Font: =Font.Verdana
                        FontSize: =8.4
                        FontWeight: =FontWeight.Semibold
                        Height: =20
                        OnSelect: =Select(Parent)
                        TabIndex: =-1
                        Text: =ThisItem.업무제목
                        VerticalAlignment: =VerticalAlign.Top
                        Width: =305
                        X: =48
                        Y: =20
                  - Title1_1:
                      Control: FluentV8/Label@1.8.6
                      Properties:
                        Font: =Font.Verdana
                        FontSize: =8
                        FontWeight: =FontWeight.Normal
                        Height: =18
                        Italic: =true
                        OnSelect: =Select(Parent)
                        TabIndex: =-1
                        Text: =ThisItem.프로젝트명
                        VerticalAlignment: =VerticalAlign.Top
                        Width: =200
                        X: =48
                  - btnAddTask:
                      Control: Button@0.0.45
                      Properties:
                        BasePaletteColor: =RGBA(156, 220, 79, 1)
                        Font: =Font.Verdana
                        FontSize: =7.5
                        Height: =20
                        OnSelect: |+
                          =// ✅ 추가버튼 btnAddTask.OnSelect (중복 허용 버전)

                          With(
                              {
                                  taskRec: LookUp(Task_DB, ID = ThisItem.ID)
                              },
                              Collect(
                                  colDailyTasks,
                                  {
                                      // Task 기준값은 유지 (나중에 집계/필터링에 씀)
                                      TaskID: taskRec.ID,

                                      // Daily_DB ID는 저장 전이니 Blank
                                      ID: Blank(),
                                      HasDaily: false,

                                      c업무_계정: taskRec.업무_계정,
                                      c프로젝트명: taskRec.프로젝트명,
                                      c업무제목: taskRec.업무제목,
                                      c업무_시작일자: taskRec.업무_시작일자,
                                      c업무_종료일자: taskRec.업무_종료일자,
                                      c상태: taskRec.상태,
                                      c상세_업무내용: taskRec.상세_업무내용,

                                      작업내용: "",
                                      작업시간: 0,
                                      작업_분류: Blank()
                                  }
                              )
                          );
                        Text: ="+ 추가"
                        Width: =52
                        X: =314
                  - BadgeCanvas1:
                      Control: Badge@0.0.24
                      Properties:
                        Content: =ThisItem.상태
                        Font: =Font.Verdana
                        FontSize: =8.7
                        Height: =20
                        Width: =42
                  - Title2_2:
                      Control: FluentV8/Label@1.8.6
                      Properties:
                        Font: =Font.Verdana
