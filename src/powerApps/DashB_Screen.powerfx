Screens:
  DashB_Screen:
    Properties:
      Fill: =RGBA(255, 255, 255, 1)
      LoadingSpinnerColor: =RGBA(98, 100, 167, 1)
      OnVisible: |+
        =// ========================================
        // DashB_Screen.OnVisible (화면 진입 시 필요한 것만)
        // ========================================

        Set(varShowNotes, false);

        // A) 선택값 초기화(원래대로)
        Set(varSelectedMember, Blank());
        Set(varSelectedAccount, Blank());
        Set(varSelProject, Blank());
        Set(varSelTaskType, Blank());

        // B) (중요) name_label.Text가 안정적으로 들어오는 환경이면 여기서 사용자명 보정
        //    - varMe를 매번 재조회하면 무거워지므로 "필요할 때만" 보정
        If(
            !IsBlank(name_label.Text) && name_label.Text <> varLoginName,
            Set(varLoginName, name_label.Text);

            Set(varMe, LookUp(UserInfo_DB, 이름_한글 = varLoginName));
            Set(varMyRole, varMe.직급2);
            Set(varMyTeam, varMe.팀);
            Set(varMyDivision, varMe.부문);

            // ✅ 역할이 바뀌거나 사용자명이 바뀐 케이스 대비: 리스트도 재생성(가볍게)
            ClearCollect(colMemberList, {Label:"전체"});
            ClearCollect(colTeamList, {Label:"전체"});

            If(
                varMyRole = "팀장",
                ForAll(
                    Filter(UserInfo_DB, 팀 = varMyTeam) As U,
                    Collect(colMemberList, {Label: U.이름_한글})
                )
            );

            If(
                varMyRole = "부문장" || varMyRole = "소장",
                With(
                    {
                        t: If(
                            varMyRole = "소장",
                            UserInfo_DB,
                            Filter(UserInfo_DB, 부문 = varMyDivision)
                        )
                    },
                    ForAll(
                        t As U,
                        With(
                            { teamName: Trim(Coalesce(U.팀, "")) },
                            If(
                                !IsBlank(teamName) &&
                                teamName <> "전체" &&
                                !(teamName in varHiddenTeams) &&
                                IsBlank(LookUp(colTeamList, Label = teamName)),
                                Collect(colTeamList, {Label: teamName})
                            )
                        )
                    )
                )
            )
        );

        // C) 기간 기본값: 이번 달(원래대로)
        Set(varPeriodMode, "이번 달");

        Set(varStartDate, Date(Year(Today()), Month(Today()), 1));
        Set(varEndDate, Date(Year(Today()), Month(Today()) + 1, 0));
        Set(varPeriodDays, DateDiff(varStartDate, varEndDate) + 1);

        // D) 기간 데이터 로딩(무거운 부분 → OnVisible 유지)
        Clear(colTeamPeriodData);

        If(
            varMyRole = "팀원" || varMyRole = "팀장",
            Collect(
                colTeamPeriodData,
                Filter(
                    Daily_DB,
                    팀 = varMyTeam &&
                    작성일자 >= varStartDate &&
                    작성일자 <= varEndDate
                )
            ),

            varMyRole = "부문장",
            With(
                { t: Filter(UserInfo_DB, 부문 = varMyDivision) },
                ForAll(
                    t As U,
                    If(
                        CountRows(Filter(colTeamPeriodData, 팀 = U.팀)) = 0,
                        Collect(
                            colTeamPeriodData,
                            Filter(
                                Daily_DB,
                                팀 = U.팀 &&
                                작성일자 >= varStartDate &&
                                작성일자 <= varEndDate
                            )
                        )
                    )
                )
            ),

            // 소장(또는 그 외)
            Collect(
                colTeamPeriodData,
                Filter(
                    Daily_DB,
                    작성일자 >= varStartDate &&
                    작성일자 <= varEndDate
                )
            )
        );

        // (이전 기간도 필요하면 그대로 유지)
        Clear(colTeamPrevPeriodData);

        If(
            varMyRole = "팀원" || varMyRole = "팀장",
            Collect(
                colTeamPrevPeriodData,
                Filter(
                    Daily_DB,
                    팀 = varMyTeam &&
                    작성일자 >= DateAdd(varStartDate, -varPeriodDays, TimeUnit.Days) &&
                    작성일자 <= DateAdd(varStartDate, -1, TimeUnit.Days)
                )
            ),

            varMyRole = "부문장",
            With(
                { t: Filter(UserInfo_DB, 부문 = varMyDivision) },
                ForAll(
                    t As U,
                    If(
                        CountRows(Filter(colTeamPrevPeriodData, 팀 = U.팀)) = 0,
                        Collect(
                            colTeamPrevPeriodData,
                            Filter(
                                Daily_DB,
                                팀 = U.팀 &&
                                작성일자 >= DateAdd(varStartDate, -varPeriodDays, TimeUnit.Days) &&
                                작성일자 <= DateAdd(varStartDate, -1, TimeUnit.Days)
                            )
                        )
                    )
                )
            ),

            Collect(
                colTeamPrevPeriodData,
                Filter(
                    Daily_DB,
                    작성일자 >= DateAdd(varStartDate, -varPeriodDays, TimeUnit.Days) &&
                    작성일자 <= DateAdd(varStartDate, -1, TimeUnit.Days)
                )
            )
        );

        // E) 컨트롤 초기화 + 집계 재생성
        Reset(ddMember);
        Select(btnRecalcDash);
    Children:
      - Header_con_6:
          Control: GroupContainer@1.5.0
          Variant: ManualLayout
          Properties:
            Fill: =RGBA(34, 35, 58, 1)
            Height: =35
            Width: =1366
          Children:
            - Label8_5:
                Control: FluentV8/Label@1.8.6
                Properties:
                  Color: =RGBA(244, 244, 243, 1)
                  Font: =Font.Verdana
                  FontSize: =14
                  FontWeight: =FontWeight.Semibold
                  Text: ="업무현황판"
                  Width: =104
                  X: =11
                  Y: =1
            - Icon4_3:
                Control: Classic/Icon@2.5.0
                Properties:
                  BorderColor: =RGBA(0, 0, 0, 0)
                  Color: =RGBA(255, 255, 255, 1)
                  DisabledBorderColor: =RGBA(243, 242, 241, 1)
                  DisabledColor: =RGBA(220, 220, 220, 1)
                  DisabledFill: =RGBA(0, 0, 0, 0)
                  Height: =25
                  HoverBorderColor: =RGBA(0, 0, 0, 0)
                  HoverColor: =ColorFade(RGBA(98, 100, 167, 1), -30%)
                  HoverFill: =RGBA(0, 0, 0, 0)
                  Icon: =Icon.Person
                  PaddingBottom: =3
                  PaddingLeft: =3
                  PaddingRight: =3
                  PaddingTop: =3
                  PressedBorderColor: =RGBA(0, 0, 0, 0)
                  PressedColor: =ColorFade(RGBA(98, 100, 167, 1), -30%)
                  PressedFill: =RGBA(0, 0, 0, 0)
                  Width: =25
                  X: =1285
                  Y: =4
            - name_label_8:
                Control: FluentV8/Label@1.8.6
                Properties:
                  Color: =RGBA(255, 255, 255, 1)
                  Font: =Font.Verdana
                  FontSize: =8
                  Height: =20
                  Text: |
                    =If(
                        IsBlank(Find("(", User().FullName)), // 괄호가 없는 경우 (이름 양식 2)
                        Concatenate(
                            Trim(Right(User().FullName, Len(User().FullName) - Find(" ", User().FullName))), // 공백 이후 성
                            Trim(Left(User().FullName, Find(" ", User().FullName))) // 공백 이전 이름
                        ),
                        Trim(Left(User().FullName, Find("(", User().FullName) - 1)) // 괄호가 있는 경우 (이름 양식 1)
                    )
                  Width: =35
                  X: =1310
                  Y: =4
            - ButtonCanvas3_23:
                Control: Button@0.0.45
                Properties:
                  BasePaletteColor: =If(currentView = "업무일지", RGBA(150,153,255,1), RGBA(200,200,200,1))
                  Font: =Font.Verdana
                  FontSize: =10
                  Height: =25
                  OnSelect: |
                    =Set(currentView, "업무일지"); // '리스트'로 상태 업데이트
                    Navigate(Daily_Screen, ScreenTransition.Fade); // Main_Screen으로 이동
                  Text: ="업무일지"
                  Width: =80
                  X: =115
                  Y: =5
            - ButtonCanvas3_24:
                Control: Button@0.0.45
                Properties:
                  BasePaletteColor: =If(currentView = "업무현황", RGBA(150,153,255,1), RGBA(200,200,200,1))
                  Font: =Font.Verdana
                  FontSize: =10
                  Height: =25
                  OnSelect: |-
                    =Set(currentView, "업무현황"); // '리스트'로 상태 업데이트
                    Navigate(Task_Screen, ScreenTransition.Fade); // Main_Screen으로 이동
                    Set(varEditMode, false);
                  Text: ="업무현황"
                  Width: =80
                  X: =200
                  Y: =5
            - ButtonCanvas3_25:
                Control: Button@0.0.45
                Properties:
                  BasePaletteColor: =If(currentView = "업무현황", RGBA(150,153,255,1), RGBA(200,200,200,1))
                  Font: =Font.Verdana
                  FontSize: =10
                  Height: =25
                  OnSelect: |-
                    =Set(currentView, "업무조회"); // '리스트'로 상태 업데이트

                    Navigate(View_Screen, ScreenTransition.Fade); // Main_Screen으로 이동
                    Set(varEditMode, false);
                  Text: ="업무조회"
                  Width: =80
                  X: =284
                  Y: =5
            - ButtonCanvas3_26:
                Control: Button@0.0.45
                Properties:
                  BasePaletteColor: =If(currentView = "일정", RGBA(150,153,255,1), RGBA(200,200,200,1))
                  Font: =Font.Verdana
                  FontSize: =10
                  Height: =25
                  OnSelect: |-
                    =Set(currentView, "일정"); // '달력'으로 상태 업데이트
                    Navigate(View_Screen, ScreenTransition.Fade); // Calendar_Screen으로 이동
                  Text: ="일정"
                  Visible: =false
                  Width: =80
                  X: =295
                  Y: =5
            - ButtonCanvas3_27:
                Control: Button@0.0.45
                Properties:
                  BasePaletteColor: =If(currentView = "대시보드", RGBA(150,153,255,1), RGBA(200,200,200,1))
                  Font: =Font.Verdana
                  FontSize: =10
                  Height: =25
                  OnSelect: |-
                    =Set(currentView, "대시보드"); // '리스트'로 상태 업데이트

                    Navigate(DashB_Screen, ScreenTransition.Fade); // Main_Screen으로 이동
                    Set(varEditMode, false);
                  Text: ="대시보드"
                  Width: =80
                  X: =368
                  Y: =5
            - name_label_9:
                Control: FluentV8/Label@1.8.6
                Properties:
                  Color: =RGBA(255, 255, 255, 1)
                  FontSize: =8
                  Height: =25
                  Text: =
                  Width: =50
                  X: =727
                  Y: =10
      - Con_Filter_1:
          Control: GroupContainer@1.5.0
          Variant: ManualLayout
          Properties:
            Fill: =RGBA(255,255,255,1)
            Height: =122
            Width: =483
            X: =9
            Y: =76
          Children:
            - rdoPeriodMode:
                Control: Radio@0.0.25
                Properties:
                  DefaultSelectedItems: |-
                    =
                    ["이번 달"]
                  Font: =Font.Verdana
                  Height: =115
                  Items: =["이번 주", "이번 달", "사용자 지정"]
                  Layout: ='RadioGroupCanvas.Layout'.Vertical
                  OnChange: |+
                    =Switch(
                        rdoPeriodMode.Selected.Value,
                        "이번 주",
                            Set(varStartDate, DateAdd(Today(), 1 - Weekday(Today(), StartOfWeek.Monday), TimeUnit.Days));
                            Set(varEndDate,   DateAdd(varStartDate, 4, TimeUnit.Days)),

                        "이번 달",
                            Set(varStartDate, Date(Year(Today()), Month(Today()), 1));
                            Set(varEndDate,   DateAdd(DateAdd(varStartDate, 1, TimeUnit.Months), -1, TimeUnit.Days)),

                        "사용자 지정",
                            Set(varStartDate, dpStart.SelectedDate);
                            Set(varEndDate,   dpEnd.SelectedDate)
                    );
                  Width: =130
                  X: =4
                  Y: =5
            - dpStart:
                Control: DatePicker@0.0.46
                Properties:
                  DisplayMode: |+
                    =If(
                        rdoPeriodMode.Selected.Value = "사용자 지정",
                        DisplayMode.Edit,
                        DisplayMode.Disabled
                    )
                  Font: =Font.Verdana
                  FontSize: =12.5
                  Format: ='DatePickerCanvas.Format'.LongAbbreviated
                  OnChange: |+
                    =If(rdoPeriodMode.Selected.Value="사용자 지정", Set(varStartDate, dpStart.SelectedDate))
                  SelectedDate: =Today()
                  Width: =160
                  X: =127
                  Y: =79
            - dpEnd:
                Control: DatePicker@0.0.46
                Properties:
                  Appearance: ='DatePickerCanvas.Appearance'.FilledDarker
                  DisplayMode: |-
                    =If(
                        rdoPeriodMode.Selected.Value = "사용자 지정",
                        DisplayMode.Edit,
                        DisplayMode.Disabled
                    )
                  Font: =Font.Verdana
                  FontSize: =12.5
                  OnChange: |+
                    =If(rdoPeriodMode.Selected.Value="사용자 지정", Set(varEndDate, dpEnd.SelectedDate))
                  SelectedDate: |+
                    =Today()
                  Width: =160
                  X: =312
                  Y: =79
            - TextCanvas11_3:
                Control: Text@0.0.51
                Properties:
                  Height: =27
                  Size: =16
                  Text: ="~"
                  VerticalAlign: =VerticalAlign.Middle
                  Weight: ='TextCanvas.Weight'.Regular
                  Width: =15
                  X: =294
                  Y: =82
            - Container19:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  Fill: |-
                    =RGBA(214, 221, 224, 0.5
                    )
                  Height: =38
                  Width: =345
                  X: =127
                  Y: =14
            - ddMember:
                Control: DropDown@0.0.45
                Properties:
                  DefaultSelectedItems: |
                    =If(
                        IsBlank(varSelectedMember),
                        [ {Label:"전체"} ],
                        [ {Label: varSelectedMember} ]
                    )
                  FontSize: =13
                  Height: =27
                  Items: |
                    =With(
                        {
                            src: If(varMyRole = "팀장", colMemberList, colTeamList)
                        },
                        SortByColumns(
                            AddColumns(
                                Filter(src, !IsBlank(Trim(Label))),   // 혹시 모를 공백 방지
                                SortKey,
                                If(Label = "전체", "0", "1" & Label)
                            ),
                            "SortKey",
                            SortOrder.Ascending
                        )
                    )
                  OnChange: |
                    =Set(
                        varSelectedMember,
                        If(
                            IsBlank(ddMember.Selected) || ddMember.Selected.Label = "전체",
                            Blank(),
                            ddMember.Selected.Label
                        )
                    );

                    Set(varSelectedAccount, Blank());
                    Set(varSelProject, Blank());
                    Set(varSelTaskType, Blank());

                    Select(btnRecalcDash);
                  Visible: =varMyRole <> "팀원"
                  Width: =143
                  X: =168
                  Y: =19
                Children:
                  - Label1:
                      Control: DropDownDataField@1.5.0
                      Variant: textualColumn
                      IsLocked: true
                      Properties:
                        FieldDisplayName: ="Label"
                        FieldName: ="Label"
                        FieldType: ="s"
                        Order: =1
            - TextCanvas14:
                Control: Text@0.0.51
                Properties:
                  Align: ='TextCanvas.Align'.End
                  Font: =Font.Verdana
                  Height: =28
                  Size: =13
                  Text: ="맴버"
                  VerticalAlign: =VerticalAlign.Middle
                  Visible: =varMyRole <> "팀원"
                  Width: =33
                  X: =127
                  Y: =19
            - btnRefresh:
                Control: Button@0.0.45
                Properties:
                  Appearance: ='ButtonCanvas.Appearance'.Secondary
                  BorderColor: =RGBA(53, 61, 63, 1)
                  BorderStyle: =BorderStyle.Solid
                  BorderThickness: =0.5
                  Font: =Font.Verdana
                  FontSize: =13
                  Height: =28
                  OnSelect: |+
                    =// ========================================
                    // btnRefresh.OnSelect  ✅ 기간 변경 + 데이터 재로딩 전용
                    // (차트 컬렉션 생성은 btnRecalcDash에서만!)
                    // ========================================

                    // 1) 기간 모드 저장
                    Set(varPeriodMode, rdoPeriodMode.Selected.Value);

                    // 2) 기간 모드에 따라 시작/종료일 계산
                    Switch(
                        varPeriodMode,

                        // ---- 이번 주 ----
                        "이번 주",
                            Set(
                                varStartDate,
                                DateAdd(
                                    Today(),
                                    -Weekday(Today(), StartOfWeek.Monday) + 1,
                                    TimeUnit.Days
                                )
                            );
                            Set(varEndDate, DateAdd(varStartDate, 6, TimeUnit.Days)),

                        // ---- 이번 달 ----
                        "이번 달",
                            Set(varStartDate, Date(Year(Today()), Month(Today()), 1));
                            Set(varEndDate, Date(Year(Today()), Month(Today()) + 1, 0)),

                        // ---- 사용자 지정 ----
                        "사용자 지정",
                            Set(varStartDate, dpStart.SelectedDate);
                            Set(varEndDate,   dpEnd.SelectedDate)
                    );

                    // 2-1) 사용자 지정 유효성(필수)
                    If(
                        varPeriodMode = "사용자 지정" &&
                        (IsBlank(varStartDate) || IsBlank(varEndDate) || varEndDate < varStartDate),
                        Notify("사용자 지정 기간을 올바르게 선택해주세요. (종료일 ≥ 시작일)", NotificationType.Error);
                        Exit()
                    );

                    // 3) 기간 일수
                    Set(varPeriodDays, DateDiff(varStartDate, varEndDate) + 1);

                    // ===============================
                    // 4) ✅ 현재 기간 데이터 재로딩 (역할별 범위)
                    // ===============================
                    Clear(colTeamPeriodData);

                    If(
                        varMyRole = "팀원" || varMyRole = "팀장",
                        Collect(
                            colTeamPeriodData,
                            Filter(
                                Daily_DB,
                                팀 = varMyTeam &&
                                작성일자 >= varStartDate &&
                                작성일자 <= varEndDate
                            )
                        ),

                        varMyRole = "부문장",
                        With(
                            { t: Filter(UserInfo_DB, 부문 = varMyDivision) },
                            ForAll(
                                t As U,
                                If(
                                    CountRows(Filter(colTeamPeriodData, 팀 = U.팀)) = 0,
                                    Collect(
                                        colTeamPeriodData,
                                        Filter(
                                            Daily_DB,
                                            팀 = U.팀 &&
                                            작성일자 >= varStartDate &&
                                            작성일자 <= varEndDate
                                        )
                                    )
                                )
                            )
                        ),

                        // 소장(또는 그 외)
                        Collect(
                            colTeamPeriodData,
                            Filter(
                                Daily_DB,
                                작성일자 >= varStartDate &&
                                작성일자 <= varEndDate
                            )
                        )
                    );

                    // ===============================
                    // 5) ✅ 이전 기간 데이터 재로딩
                    // ===============================
                    Clear(colTeamPrevPeriodData);

                    If(
                        varMyRole = "팀원" || varMyRole = "팀장",
                        Collect(
                            colTeamPrevPeriodData,
                            Filter(
                                Daily_DB,
                                팀 = varMyTeam &&
                                작성일자 >= DateAdd(varStartDate, -varPeriodDays, TimeUnit.Days) &&
                                작성일자 <= DateAdd(varStartDate, -1, TimeUnit.Days)
                            )
                        ),

                        varMyRole = "부문장",
                        With(
                            { t: Filter(UserInfo_DB, 부문 = varMyDivision) },
                            ForAll(
                                t As U,
                                If(
                                    CountRows(Filter(colTeamPrevPeriodData, 팀 = U.팀)) = 0,
                                    Collect(
                                        colTeamPrevPeriodData,
                                        Filter(
                                            Daily_DB,
                                            팀 = U.팀 &&
                                            작성일자 >= DateAdd(varStartDate, -varPeriodDays, TimeUnit.Days) &&
                                            작성일자 <= DateAdd(varStartDate, -1, TimeUnit.Days)
                                        )
                                    )
                                )
                            )
                        ),

                        // 소장(또는 그 외)
                        Collect(
                            colTeamPrevPeriodData,
                            Filter(
                                Daily_DB,
                                작성일자 >= DateAdd(varStartDate, -varPeriodDays, TimeUnit.Days) &&
                                작성일자 <= DateAdd(varStartDate, -1, TimeUnit.Days)
                            )
                        )
                    );

                    // ===============================
                    // 6) 🔥 모든 선택 초기화 (기간 바뀌면 당연히 초기화가 안전)
                    // ===============================
                    Set(varSelectedMember, Blank());
                    Set(varSelectedAccount, Blank());
                    Set(varSelProject, Blank());
                    Set(varSelTaskType, Blank());

                    Reset(ddMember);

                    // ===============================
                    // 7) 집계/차트 재계산은 btnRecalcDash가 담당
                    // ===============================
                    Select(btnRecalcDash);
                  Text: ="조회"
                  Width: =90
                  X: =376
                  Y: =18
      - btnRecalcDash:
          Control: Button@0.0.45
          Properties:
            Height: =21
            OnSelect: |+
              =// ========================================
              // btnRecalcDash.OnSelect
              // - 대분류(colAccAgg) 색 유지
              // - 프로젝트(colProjChart) 색 제거, 퍼센트 정상화(0~100)
              // ========================================

              // 1) 작업_분류
              ClearCollect(
                  colWorkTagAgg,
                  With(
                      {
                          Base: Filter(
                              colTeamPeriodData,
                              (IsBlank(varSelectedAccount) || 업무_계정 = varSelectedAccount) &&
                              If(
                                  IsBlank(varSelectedMember),
                                  true,
                                  If(varMyRole = "팀장", 작성자 = varSelectedMember, 팀 = varSelectedMember)
                              ) &&
                              (IsBlank(varSelProject) || 프로젝트명 = varSelProject) &&
                              (IsBlank(varSelTaskType) || 작업_분류 = varSelTaskType)
                          )
                      },
                      With(
                          { TotalH: Sum(Base, 작업시간) },
                          Sort(
                              AddColumns(
                                  GroupBy(
                                      AddColumns(
                                          Base,
                                          TagText,
                                          If(IsBlank(작업_분류), "미분류", 작업_분류)
                                      ),
                                      TagText,
                                      G
                                  ),
                                  Tag,   TagText,
                                  Hours, Sum(G, 작업시간),
                                  Pct,   If(TotalH > 0, Sum(G, 작업시간)/TotalH, 0)
                              ),
                              Hours,
                              SortOrder.Descending
                          )
                      )
                  )
              );

              // 2) 대분류(업무_계정) - Color 유지
              ClearCollect(
                  colAccAgg,
                  With(
                      {
                          Base: Filter(
                              colTeamPeriodData,
                              If(
                                  IsBlank(varSelectedMember),
                                  true,
                                  If(varMyRole = "팀장", 작성자 = varSelectedMember, 팀 = varSelectedMember)
                              )
                          ),
                          TotalH: Sum(
                              Filter(
                                  colTeamPeriodData,
                                  If(
                                      IsBlank(varSelectedMember),
                                      true,
                                      If(varMyRole = "팀장", 작성자 = varSelectedMember, 팀 = varSelectedMember)
                                  )
                              ),
                              작업시간
                          )
                      },
                      With(
                          {
                              T: SortByColumns(
                                  AddColumns(
                                      GroupBy(AddColumns(Base, AccKey, Trim(업무_계정)), AccKey, G),
                                      Label, AccKey,
                                      Hours, Sum(G, 작업시간),
                                      Pct, If(TotalH > 0, Sum(G, 작업시간)/TotalH, 0)
                                  ),
                                  "Hours",
                                  SortOrder.Descending
                              )
                          },
                          ForAll(
                              Sequence(CountRows(T)) As S,
                              With(
                                  { r: Last(FirstN(T, S.Value)) },
                                  {
                                      RowNo: S.Value,
                                      Label: r.Label,
                                      Hours: r.Hours,
                                      Pct:   r.Pct,
                                      Color: Switch(
                                          S.Value,
                                          1,  RGBA(27, 94, 32, 1),
                                          2,  RGBA(30, 136, 229, 1),
                                          3,  RGBA(239, 108, 0, 1),
                                          4,  RGBA(56, 142, 60, 1),
                                          5,  RGBA(0, 137, 123, 1),
                                          6,  RGBA(142, 36, 170, 1),
                                          7,  RGBA(124, 179, 66, 1),
                                          8,  RGBA(3, 155, 229, 1),
                                          9,  RGBA(251, 192, 45, 1),
                                          10, RGBA(144, 164, 174, 1),
                                          11, RGBA(189, 189, 189, 1),
                                          12, RGBA(224, 224, 224, 1)
                                      )
                                  }
                              )
                          )
                      )
                  )
              );

              // 3) 프로젝트 집계(시간만)
              ClearCollect(
                  colProjAgg,
                  With(
                      {
                          Base0: Filter(
                              colTeamPeriodData,
                              If(
                                  IsBlank(varSelectedMember),
                                  true,
                                  If(varMyRole = "팀장", 작성자 = varSelectedMember, 팀 = varSelectedMember)
                              ) &&
                              (IsBlank(varSelectedAccount) || 업무_계정 = varSelectedAccount)
                          )
                      },
                      Sort(
                          AddColumns(
                              GroupBy(Base0, OData__xd504__xb85c__xc81d__xd2b8__xba0, G),
                              Label, OData__xd504__xb85c__xc81d__xd2b8__xba0,
                              Hours, Sum(G, 작업시간)
                          ),
                          Hours,
                          SortOrder.Descending
                      )
                  )
              );

              // 4) 프로젝트 총합
              Set(varProjTotalHours, Sum(colProjAgg, Hours));

              // varProjTotalHours는 이미 만들어져 있다고 가정
              ClearCollect(
                  colProjChart,
                  ForAll(
                      colProjAgg As R,
                      With(
                          { p: If(varProjTotalHours > 0, R.Hours / varProjTotalHours, 0) },
                          {
                              Label:   R.Label,
                              Hours:   R.Hours,

                              // ✅ 차트 표시용 정수 퍼센트
                              PctVal:  Round(p * 100, 0),

                              // ✅ 갤러리 표시용 텍스트
                              PctText: Text(Round(p * 100, 0), "0") & "%"
                          }
                      )
                  )
              );
            Visible: =false
            Width: =56
            X: =478
            Y: =46
