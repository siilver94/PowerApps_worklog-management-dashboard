                        Y: =4
            - conTrendTop3_1:
                Control: GroupContainer@1.5.0
                Variant: ManualLayout
                Properties:
                  ContentLanguage: =
                  Height: =191
                  Width: =200
                  X: =3
                  Y: =156
                Children:
                  - TextCanvas11_1:
                      Control: Text@0.0.51
                      Properties:
                        Font: =Font.Verdana
                        Height: =26
                        Size: =12
                        Text: ="전 기간 대비 주요 변화 Top3"
                        Weight: ='TextCanvas.Weight'.Semibold
                        Width: =172
                        X: =15
                        Y: =9
                  - galTrendTop3:
                      Control: Gallery@2.15.0
                      Variant: BrowseLayout_Vertical_TwoTextOneImageVariant_pcfCore
                      Properties:
                        BorderColor: =RGBA(243, 242, 241, 1)
                        FocusedBorderColor: =RGBA(98, 100, 167, 1)
                        FocusedBorderThickness: =2
                        Height: =156
                        Items: |
                          =With(
                              {
                                  // ✅ 현재기간 Base (필터 반영)
                                  Cur:
                                      Filter(
                                          colTeamPeriodData,
                                          If(
                                              IsBlank(varSelectedMember),
                                              true,
                                              If(
                                                  varMyRole = "팀장",
                                                  작성자 = varSelectedMember,
                                                  팀 = varSelectedMember
                                              )
                                          ) &&
                                          (IsBlank(varSelectedAccount) || Trim(OData__xc5c5__xbb34___xacc4__xc815_) = Trim(varSelectedAccount)) &&
                                          (IsBlank(varSelProject) || 프로젝트명 = varSelProject) &&
                                          (IsBlank(varSelTaskType) || 작업_분류 = varSelTaskType)
                                      ),

                                  // ✅ 이전기간 Base (필터 반영)
                                  Prev:
                                      Filter(
                                          colTeamPrevPeriodData,
                                          If(
                                              IsBlank(varSelectedMember),
                                              true,
                                              If(
                                                  varMyRole = "팀장",
                                                  작성자 = varSelectedMember,
                                                  팀 = varSelectedMember
                                              )
                                          ) &&
                                          (IsBlank(varSelectedAccount) || Trim(OData__xc5c5__xbb34___xacc4__xc815_) = Trim(varSelectedAccount)) &&
                                          (IsBlank(varSelProject) || 프로젝트명 = varSelProject) &&
                                          (IsBlank(varSelTaskType) || 작업_분류 = varSelTaskType)
                                      )
                              },
                              With(
                                  {
                                      Keys:
                                          RenameColumns(
                                              Distinct(
                                                  Ungroup(
                                                      Table(
                                                          { T: Cur },
                                                          { T: Prev }
                                                      ),
                                                      T
                                                  ),
                                                  Trim(OData__xc5c5__xbb34___xacc4__xc815_)
                                              ),
                                              Value,
                                              AccKey
                                          )
                                  },
                                  With(
                                      {
                                          T1:
                                              AddColumns(
                                                  Keys As K,
                                                  CurHours,
                                                  Sum(
                                                      Filter(Cur, Trim(OData__xc5c5__xbb34___xacc4__xc815_) = K.AccKey),
                                                      작업시간
                                                  ),
                                                  PrevHours,
                                                  Sum(
                                                      Filter(Prev, Trim(OData__xc5c5__xbb34___xacc4__xc815_) = K.AccKey),
                                                      작업시간
                                                  )
                                              )
                                      },
                                      FirstN(
                                          SortByColumns(
                                              AddColumns(
                                                  T1 As R,
                                                  DiffHours, R.CurHours - R.PrevHours,
                                                  DiffAbs,  Abs(R.CurHours - R.PrevHours)
                                              ),
                                              "DiffAbs",
                                              SortOrder.Descending
                                          ),
                                          3
                                      )
                                  )
                              )
                          )
                        Width: =176
                        Y: =35
                      Children:
                        - Rectangle6_1:
                            Control: Rectangle@2.3.0
                            Properties:
                              BorderColor: =RGBA(243, 242, 241, 1)
                              DisabledFill: =RGBA(0,0,0,0)
                              Fill: =RGBA(0,0,0,0)
                              FocusedBorderColor: =RGBA(98, 100, 167, 1)
                              Height: =Parent.TemplateHeight
                              HoverFill: =RGBA(0,0,0,0)
                              OnSelect: =Select(Parent)
                              PressedFill: =RGBA(0,0,0,0)
                              TabIndex: =0
                              Width: =193
                        - Title7_1:
                            Control: FluentV8/Label@1.8.6
                            Properties:
                              Font: =Font.Verdana
                              FontSize: =10
                              FontWeight: =FontWeight.Normal
                              Height: =24
                              OnSelect: =Select(Parent)
                              TabIndex: =-1
                              Text: =ThisItem.AccKey
                              VerticalAlignment: =VerticalAlign.Top
                              Width: =68
                              X: =3
                              Y: =12
                        - Icon10_1:
                            Control: Classic/Icon@2.5.0
                            Properties:
                              BorderColor: =RGBA(0, 0, 0, 0)
                              Color: |-
                                =If(
                                    ThisItem.DiffHours > 0,
                                    Color.Red,
                                    If(
                                        ThisItem.DiffHours < 0,
                                        Color.Blue,
                                        Color.Gray
                                    )
                                )
                              DisabledBorderColor: =RGBA(243, 242, 241, 1)
                              DisabledColor: =RGBA(220, 220, 220, 1)
                              DisabledFill: =RGBA(0, 0, 0, 0)
                              Height: =25
                              HoverBorderColor: =RGBA(0, 0, 0, 0)
                              HoverColor: =ColorFade(RGBA(98, 100, 167, 1), -30%)
                              HoverFill: =RGBA(0, 0, 0, 0)
                              Icon: |-
                                =If(
                                    ThisItem.DiffHours > 0,
                                    Icon.ArrowUp,
                                    If(
                                        ThisItem.DiffHours < 0,
                                        Icon.ArrowDown,RemoveFlags
                                )
                                )
                              OnSelect: =Select(Parent)
                              PaddingBottom: =3
                              PaddingLeft: =3
                              PaddingRight: =3
                              PaddingTop: =3
                              PressedBorderColor: =RGBA(0, 0, 0, 0)
                              PressedColor: =ColorFade(RGBA(98, 100, 167, 1), -30%)
                              PressedFill: =RGBA(0, 0, 0, 0)
                              Width: =25
                              X: =71
                              Y: =12
                        - Subtitle2_2:
                            Control: FluentV8/Label@1.8.6
                            Properties:
                              Color: |
                                =If(
                                    ThisItem.DiffHours > 0,
                                    Color.Red,
                                    If(
                                        ThisItem.DiffHours < 0,
                                        Color.Blue,
                                        Color.Gray
                                    )
                                )
                              FontSize: =9
                              FontWeight: =FontWeight.Normal
                              Height: =24
                              OnSelect: =Select(Parent)
                              TabIndex: =-1
                              Text: |
                                =If(
                                    ThisItem.DiffHours > 0,
                                    "+" & Text(ThisItem.DiffHours, "0.0") & " 시간 ",
                                    If(
                                        ThisItem.DiffHours < 0,
                                        Text(ThisItem.DiffHours, "") & " 시간",
                                        "변화 없음"
                                    )
                                )
                              VerticalAlignment: =VerticalAlign.Top
                              Width: =124
                              X: =99
                              Y: =13
            - HtmlText1_1:
                Control: HtmlViewer@2.1.0
                Properties:
                  DisabledBorderColor: =RGBA(200, 198, 196, 1)
                  Font: =Font.Verdana
                  Height: =270
                  HtmlText: |+
                    =With(
                        {
                            T: galTrendTop3.AllItems,

                            // 증가 Top1
                            IncRec: First(Sort(Filter(galTrendTop3.AllItems, DiffHours > 0), DiffHours, SortOrder.Descending)),

                            // 감소 Top1/Top2 (가장 많이 감소한 순 = DiffHours 오름차순)
                            DecTable: FirstN(Sort(Filter(galTrendTop3.AllItems, DiffHours < 0), DiffHours, SortOrder.Ascending), 2)
                        },
                        If(
                            CountRows(T) = 0 || Sum(T, Abs(DiffHours)) = 0,
                            "<div style='font-size:13px; line-height:1.6;'>
                                <b>📌 주요 변화</b><br/>
                                이번 기간에는 유의미한 변화가 없습니다.
                            </div>",
                            With(
                                {
                                    TopIncName: If(IsBlank(IncRec), Blank(), IncRec.AccKey),
                                    TopIncH:    If(IsBlank(IncRec), Blank(), IncRec.DiffHours),

                                    Dec1: If(CountRows(DecTable) >= 1, First(DecTable).AccKey, Blank()),
                                    Dec2: If(CountRows(DecTable) >= 2, Last(DecTable).AccKey, Blank())
                                },
                                "<div style='font-size:13px; line-height:1.6;'>

                                    <b>📌 주요 변화</b><br/>" &

                                    If(
                                        !IsBlank(TopIncName),
                                        "• <b>" & TopIncName & "</b> 작업시간이 <b>+" & Text(TopIncH, "0.#") & "시간</b> 증가",
                                        "• 증가 항목은 두드러지지 않았습니다"
                                    ) &

                                    If(
                                        !IsBlank(Dec1) || !IsBlank(Dec2),
                                        ",<br/>• <b>" &
                                            Coalesce(Dec1, "") &
                                            If(!IsBlank(Dec1) && !IsBlank(Dec2), "</b>, <b>", "") &
                                            Coalesce(Dec2, "") &
                                        "</b>는 감소하며 비중이 이동했습니다.",
                                        ".</b>"
                                    ) &

                                    "<br/><br/><b>⚠️ 주의 포인트</b><br/>" &
                                    If(
                                        !IsBlank(TopIncName),
                                        "• 작업시간 증가가 <b>" & TopIncName & "</b>에 집중되는 흐름이 관찰됩니다.",
                                        "• 작업시간 변화가 특정 항목에 집중되는지 추가 관찰이 필요합니다."
                                    ) &

                                    "<br/><br/><b>👉 확인 필요</b><br/>" &
                                    If(
                                        !IsBlank(TopIncName),
                                        "• " & TopIncName & " 증가가 <b>일시적 투입</b>인지,<br/>• 또는 <b>지속적인 업무 전환</b>인지 확인이 필요합니다.",
                                        "• 변화 요인이 <b>일시적</b>인지 <b>추세</b>인지 확인이 필요합니다."
                                    ) &

                                "</div>"
                            )
                        )
                    )
                  Size: =8
                  Width: =329
                  X: =200
      - member_detail:
          Control: Text@0.0.51
          Properties:
            Height: =20
            Size: =5
            Text: =varMyRole & " / " & varMyDivision & " / " & varMyTeam
