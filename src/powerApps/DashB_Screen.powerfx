                                          (IsBlank(varSelTaskType) || 작업_분류 = varSelTaskType)
                                      ),
                                      작성자
                                  ))
                              },
                              With(
                                  { TotalHours: Sum(Base, 작업시간) },
                                  Text(
                                      If(PeopleCount > 0, TotalHours / PeopleCount, 0),
