// ✅ App.OnStart (최상단) - 초기 준비 플래그만
// name_label.Text는 초기엔 Blank일 수 있어, 여기서 팀을 확정하지 않음.
Set(varAppReady, true);


//// ── 0. 날짜·상태 기본 변수 ─────────────────────
//Set(varSelProject, "");
Set(varYear,  Year(Today()));
//Set(varMonth, Month(Today()));
Set(varFirstDayOfMonth, Date(Year(Today()), Month(Today()), 1));
Set(varSelectedDate, Today());
//Set(FilterStatus,  "진행중");
Set(FilterMode,    "All");
Set(currentView,   "업무일지");
Set(SelectedItem , {});
Set(varFilterMode, "All");
Set(varToastMessage, "");  Set(varShowToast , false);
Set(varToastMessage2,"");  Set(varShowToast2, false);

Set(varSelectedAccount, "");

// 타입 고정용 (업무_계정은 텍스트니까 문자열로)
Set(varSelAccount, "");

// 이후부터 Blank() 사용 가능
Set(varSelAccount, Blank());

// 프로젝트 모드도 같이
Set(varProjectMode, "View");

Concurrent(
    /* 1) (굳이 필요 없다면) 변수를 없애도 OK */
    Set(
        varCutoffDate,
        DateAdd(Today(), -365,TimeUnit.Days)
    ),

    /* 2) 날짜를 다시 계산해서 사용 (독립) */
    ClearCollect(
        colMyTasks,
        ShowColumns(
            Filter(
                Task_DB,
                작성자 = varMyName,
                업무_시작일자 >= DateAdd(Today(), -365,TimeUnit.Days)
            ),
            업무제목, 업무_시작일자, 상태, 프로젝트명
        )
    )
);



/* 2) 상태 선택 컬렉션 – 기본 전부 선택 */
ClearCollect(
    colSelStatus,
    Table( {Value:"시작전"}, {Value:"진행중"}, {Value:"완료"} )
);


/* ─── 기존 코드 위·아래 원하는 위치에 추가 ─── */
Set(varShowPlanned,    false);   // 시작전(Planned)   → 기본 OFF
Set(varShowInProgress, true );   // 진행중(InProgress)→ 기본 ON
Set(varShowCompleted,  false);   // 완료(Completed)   → 기본 OFF
 
//// ── 1. 사용자 정보 (회사 메일은 모두 소문자) ─────
Set(varMyEmail, Lower(User().Email));
 
/* 1-A) 팀 · 이름 */
Set(
    varMyTeam,
    LookUp(
        UserInfo_DB,
        'e-mail' = varMyEmail,   // ← Email 컬럼
        팀                        // ← 팀 컬럼
    )
);
Set(
    varMyName,
    LookUp(
        UserInfo_DB,
        'e-mail' = varMyEmail,
        이름_한글                  // ← 한글 이름 컬럼
    )
);
Set(varDisplayName, varMyName);

//// ── 작업_분류(키워드) 매핑 테이블 (업무_계정별) ───────────────
// - Account: 업무_계정 값 (colDailyTasks의 c업무_계정과 동일한 값이어야 함)
