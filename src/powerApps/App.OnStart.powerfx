        {Account:"출장", Tag:"테스트", Order:1},
        {Account:"출장", Tag:"업체 방문", Order:2},
        {Account:"출장", Tag:"회의", Order:3},
        {Account:"출장", Tag:"세미나", Order:4},
        {Account:"출장", Tag:"교육", Order:5},
        {Account:"출장", Tag:"기타", Order:6}
    )
);
 
 
// ── 최근 365일 기준일 (이미 varCutoffDate 만들고 있으니 그걸 써도 됨)
Set(varCutoffDate, DateAdd(Today(), -365, TimeUnit.Days));

// (권장) 최신 데이터 보장
Refresh(Daily_DB);

//// ── 2. 최근 365일 팀 데이터 ▶ colDaily_365_Team ─────
ClearCollect(
    colDaily_365_Team,
    Filter(Daily_DB, 작성일자 >= varCutoffDate && 팀 = varMyTeam)
);

//// ── 2-B. 최근 365일 전체 데이터 ▶ colDaily_365_All ─────
ClearCollect(
    colDaily_365_All,
    Filter(Daily_DB, 작성일자 >= varCutoffDate)
);

//// ── 3. 프로젝트 목록 (정규화 + Value 통일 + Blank 제거) ─────

// ✅ App.OnStart - 프로젝트 목록 캐시 생성 (Value 컬럼 테이블)
// - colDaily_365_Team에서 프로젝트명(원본 컬럼)을 Trim 후 중복 제거
// - 빈 값 제외
// - Value 기준 정렬

// ✅ App.OnStart - 프로젝트 목록 캐시 생성 (Value 컬럼 테이블)
// - colDaily_365_Team에서 프로젝트명(원본 컬럼)을 Trim 후 중복 제거
// - 빈 값 제외
// - Value 기준 정렬

// ✅ App.OnStart - 프로젝트 목록 캐시 생성 (Value 컬럼 테이블)
// - colDaily_365_Team에서 프로젝트명(원본 컬럼)을 Trim 후 중복 제거
// - 빈 값 제외
// - Value 기준 정렬

// ── colProjectList: 팀별 모드 (colTargetAuthors가 Task_DB에 등록한 프로젝트) ──
// Task_DB는 작성자 필터 시 수십~수백건 → Delegation 문제 없음


// ── colAllProjects: 프로젝트별 모드 (Project_DB 전체 — 68건, 한도 없음) ──
ClearCollect(
    colAllProjects,
    Sort(
        Distinct(
            AddColumns(
                Filter(Project_DB, !IsBlank(프로젝트명)),
                Value,
                Trim(프로젝트명)
            ),
            Value
        ),
        Value,
        SortOrder.Ascending
    )
);


Set(varShowDetail, false);   // 팝업 표시 여부
//Set(varSelID,     Blank());  // 선택된 Daily_DB PK(ID)


// 이메일 기준으로 매칭 (name_label.Text 파싱 불안정 문제 우회)
Set(varMyRole, LookUp(UserInfo_DB, 'e-mail' = varMyEmail, 직급2));
Set(varMyDivision, LookUp(UserInfo_DB, 'e-mail' = varMyEmail, 부문));


//Set(varMyTeam, varMyInfo.'팀');
Set(varViewMode, "팀별");   // 🔸 새 전역 변수 (기본값: 팀별)

// 업무_계정 선택 시 작업_구분 보이게 하기
Set(varSelTaskType, "");   // 타입(텍스트) 고정용 1회 초기화
Set(varSelTaskType, Blank());

Set(varSelProject, "");    // (권장) 이것도 동일하게 타입 고정
Set(varSelProject, Blank());


// ========================================
// ★★★★★★★★★★ 대시보드 화면App.OnStart  (1회성 준비 영역) ★★★★★★★★★★
// ========================================

// 0) 앱 준비 플래그 (옵션)
Set(varAppReady, false);

// 1) 숨김 팀 목록(필요한 만큼 추가)
Set(
    varHiddenTeams,
    ["연구관리팀2", "엔진개발팀2", "제품개발DX팀"]
);

// 2) 팔레트(대분류 차트/legend 색 유지용) ✅
Set(
    varAccPalette,
    [
        RGBA(27, 94, 32, 1),
        RGBA(30, 136, 229, 1),
        RGBA(239, 108, 0, 1),
        RGBA(56, 142, 60, 1),
        RGBA(0, 137, 123, 1),
        RGBA(142, 36, 170, 1),
        RGBA(124, 179, 66, 1),
        RGBA(3, 155, 229, 1),
        RGBA(251, 192, 45, 1),
        RGBA(144, 164, 174, 1),
        RGBA(189, 189, 189, 1),
        RGBA(224, 224, 224, 1)
    ]
);

// 3) 로그인 사용자 이름(기본값)
Set(varLoginName, Coalesce(User().FullName, ""));

// 4) 사용자 정보 1회 조회
Set(
    varMe,
    LookUp(UserInfo_DB, 이름_한글 = varLoginName)
);

// 5) ddMember용 리스트 2종 생성(1회)
//    - colMemberList: 팀장 전용(팀원)
//    - colTeamList: 부문장/소장 전용(팀)
ClearCollect(colMemberList, {Label:"전체"});
ClearCollect(colTeamList, {Label:"전체"});

// 팀장(또는 팀원)일 때: 팀원 리스트 준비
If(
    varMyRole = "팀장",
    ForAll(
        Filter(UserInfo_DB, 팀 = varMyTeam) As U,
        Collect(colMemberList, {Label: U.이름_한글})
    )
);

// 부문장/소장일 때: 팀 리스트 준비
If(
    varMyRole = "부문장" || varMyRole = "소장",
    With(
        {
            t: If(
                varMyRole = "소장",
                UserInfo_DB,
                Filter(UserInfo_DB, 부문 = varMyDivision)
            )
        },
        ForAll(
            t As U,
            With(
                { teamName: Trim(Coalesce(U.팀, "")) },
                If(
                    !IsBlank(teamName) &&
                    teamName <> "전체" &&
                    !(teamName in varHiddenTeams) &&
                    IsBlank(LookUp(colTeamList, Label = teamName)),
                    Collect(colTeamList, {Label: teamName})
                )
            )
        )
    )
);

Set(varAppReady, true);

// ── colUsers 캐시 (역할별 필터링에 사용) ──
ClearCollect(colUsers, UserInfo_DB);

// ── colTargetAuthors: 역할별 조회 대상 작성자 목록 ──
ClearCollect(
    colTargetAuthors,
    Switch(
        varMyRole,
        "소장",   Filter(colUsers, 직급2 = "팀장"),
        "부문장", Filter(colUsers, 직급2 = "팀장" && 부문 = varMyDivision),
        "팀장",   Filter(colUsers, 팀 = varMyTeam),
                  Filter(colUsers, 팀 = varMyTeam)  // 팀원도 팀 전체로 변경 ✅
    )
);



// ── colTargetAuthors 아래에 이걸 붙여 ──
ClearCollect(
    colProjectList,
    Sort(
        Distinct(
            AddColumns(
                Filter(
                    Task_DB,
                    작성자 in colTargetAuthors.이름_한글 &&
                    !IsBlank(프로젝트명)
                ),
                Value,
                Trim(프로젝트명)
            ),
            Value
        ),
        Value,
        SortOrder.Ascending
    )
);
